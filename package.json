{
  "name": "ca-liquidity-dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply ca_liquidity --local",
    "migrate:remote": "wrangler d1 migrations apply ca_liquidity --remote",
    "migrate:list": "wrangler d1 migrations list ca_liquidity --remote",
    "export:snapshots": "wrangler d1 execute ca_liquidity --remote --json --command \"SELECT date, factors_json, tsx, qe_qt_regime FROM daily_snapshot WHERE tsx IS NOT NULL ORDER BY date\" > scripts/data/snapshots.json"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "wrangler": "^3.80.0"
  }
}
